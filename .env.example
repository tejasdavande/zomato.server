# Copy this file to .env and fill in real values.

# Port the HTTP server listens on
PORT=3000

# Secret used to sign JWTs (use a long random string)
JWT_SECRET_KEY=change_me_to_a_long_random_string

# --- Database ---
# Option A (recommended): a full connection string for Atlas or local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/zomato

# Option B: provide individual Atlas credentials instead of MONGODB_URI
# DB_USERNAME=
# DB_PASSWORD=
# DB_NAME=zomato
